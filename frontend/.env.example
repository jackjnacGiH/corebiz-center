# CoreBiz Center frontend env vars
# Copy to .env.local before running `npm run dev`

# Supabase (CoreBiz Center project)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxx

# LINE Login
VITE_LINE_CHANNEL_ID=2001234567
VITE_LINE_CALLBACK_URL=http://localhost:5173/auth/line-callback
# In production set to: https://www.corebiz.online/auth/line-callback

# Optional: RAG API endpoint (if exposing a separate retrieval endpoint)
VITE_RAG_API_URL=
